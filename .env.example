# Server Configuration
PORT=3000
NODE_ENV=development

# Server URL (for generating URLs in responses)
SERVER_URL=http://localhost:3000

# MongoDB Connection
MONGO_URI=mongodb://localhost:27017/project_management

# CORS Origin (comma-separated for multiple origins)
CORS_ORIGIN=http://localhost:5173

# JWT Access Token
ACCESS_TOKEN_SECRET=your_super_secret_access_token_key_min_32_chars
ACCESS_TOKEN_EXPIRY=1d

# JWT Refresh Token
REFRESH_TOKEN_SECRET=your_super_secret_refresh_token_key_min_32_chars
REFRESH_TOKEN_EXPIRY=10d

# Forgot Password Redirect URL
FORGOT_PASSWORD_REDIRECT_URL=http://localhost:5173/reset-password

# Mailtrap SMTP (for development email)
# Get these from https://mailtrap.io/
MAILTRAP_SMTP_HOST=sandbox.smtp.mailtrap.io
MAILTRAP_SMTP_PORT=2525
MAILTRAP_SMTP_USER=your_mailtrap_username
MAILTRAP_SMTP_PASS=your_mailtrap_password
